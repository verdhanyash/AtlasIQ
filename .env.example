# AtlasIQ Environment Variables
# Copy this file to .env and fill in the values.
# These override values in configs/default.yaml.

# ─── Server ───
# ATLASIQ_SERVER__HOST=0.0.0.0
# ATLASIQ_SERVER__PORT=8000

# ─── PostgreSQL ───
ATLASIQ_DATABASE__HOST=localhost
ATLASIQ_DATABASE__PORT=5432
ATLASIQ_DATABASE__NAME=atlasiq
ATLASIQ_DATABASE__USER=atlasiq
ATLASIQ_DATABASE__PASSWORD=atlasiq

# ─── Qdrant ───
ATLASIQ_QDRANT__HOST=localhost
ATLASIQ_QDRANT__PORT=6333

# ─── LLM Provider ───
# Options: ollama, nvidia, openai
ATLASIQ_LLM__PROVIDER=ollama
ATLASIQ_LLM__MODEL=gemma3:4b

# ─── Ollama (local) ───
ATLASIQ_OLLAMA__BASE_URL=http://localhost:11434

# ─── NVIDIA Build (cloud) ───
# ATLASIQ_NVIDIA__API_KEY=your-nvidia-api-key-here

# ─── OpenAI (cloud) ───
# ATLASIQ_OPENAI__API_KEY=your-openai-api-key-here

# ─── Ingestion ───
# ATLASIQ_INGESTION__WATCHED_FOLDER=./watched_documents
# ATLASIQ_INGESTION__MAX_FILE_SIZE_MB=50

# ─── Embedding ───
# ATLASIQ_EMBEDDING__MODEL_NAME=nomic-ai/nomic-embed-text-v1.5

# ─── Retrieval ───
# ATLASIQ_RETRIEVAL__DENSE_TOP_K=20
# ATLASIQ_RETRIEVAL__RERANK_TOP_K=5

# ─── Cache ───
# ATLASIQ_CACHE__ENABLED=true
# ATLASIQ_CACHE__MAX_SIZE=100
# ATLASIQ_CACHE__TTL_SECONDS=3600
